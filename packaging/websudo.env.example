# websudo environment configuration example.
# Copy this file to /etc/websudo/websudo.env and edit values as needed.

# Address for the local websudo approval daemon.
WEBSUDO_WEB_ADDR=127.0.0.1:17878

# How long an askpass approval request may stay valid, in seconds.
WEBSUDO_APPROVAL_TIMEOUT_SECONDS=600

# Path to the system sudo binary.
WEBSUDO_SUDO_PATH=/usr/bin/sudo

# Path to websudo-askpass. Leave empty to resolve it from PATH.
WEBSUDO_ASKPASS_PATH=
